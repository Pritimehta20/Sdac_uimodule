 <body>
 <u><em><center><h1>Register to Travel and Adventure</h1></center></em></u>
 <hr>
  <center><form method="post" action="login.html">
	<table>
  <tr>
	<td><label>Name:</label></td>
	<td><input type="text" name="" pattern="A-Za-z+\s"></td>
  </tr>
  <tr>
	<td><label>Email:</label></td>
	<td><input type="email" name=""></td>
  </tr>
  <tr>
	<td><label>Phone:</label></td>
	<td><input type="tel" name=""></td>
  </tr>
  <tr>
	<td><label>Address:</label></td>
	<td><input type="text" name=""></td>
  </tr>
  <tr>
	<td><label>Username:</label></td>
	<td><input type="text" name="" pattern="A-Za-z+"></td>
  </tr>
  <tr>
	<td><label>Password:</label></td>
	<td><input type="password" name=""></td>
  </tr>
  <tr>
	<td><input type="submit"></td>
	<td><input type="reset"></td>
  </tr>
  </table>
  </form></center>
