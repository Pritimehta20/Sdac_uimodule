  <center><h1>Reserve a Table</h1></center>
 <form method="post" action="">
	<center><table>
	<tr>
		<td><label>Name:</label></td>
		<td><input type="text" required pattern="A-Za-z+\s"></input></td>
	</tr>
	<tr>
		<td><label>Email</label></td>
		<td><input type="email" name="" required></td>
	</tr>
	<tr>
		<td><label>Phone:</label></td>
		<td><input type="tel" name="" required></td>
	</tr>
	<tr>
		<td><label>Date of visit:</label></td>
		<td><input type="date" name="" required></td>
	</tr>
	<tr>
		<td><label>Time:</label></td>
		<td><input type="datetime-local" name="" required></td>
	</tr>
	<tr>
		<td>Number of Guests:</td>
		<td><select name="" required>
			<option value="1" selected>1</option>
			<option value="2">2</option>
			<option value="3">3</option>
			<option value="4">4</option>
			<option value="5">5</option>
			<option value="6">6</option>
			<option value="7">7</option>
			<option value="8">8</option>
			<option value="9">9</option>
			<option value="10">10</option>
		</select></td>
	</tr>
	<tr>
		<td>Special Request:</td>
		<td><textarea name="" rows="" cols="" required></textarea></td>
	</tr>
	<tr>
		<td><center><input type="submit"></center></td>
	</tr>
	</table></center>
  </form>
 
  
